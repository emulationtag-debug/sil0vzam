{
  "manifest_version": 3,
  "name": "Sil0vzam",
  "version": "1.0.0",
  "description": "An audio recognition extension for the browser.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
  },
  "background": {
    "service_worker": "background.js"
  }
}
